{
  "name": "world-editor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build_rego": "regolith run",
    "build_publish_tsc": "node esbuild.config.mjs --release",
    "build_tsc": "node esbuild.config.mjs",
    "build": "npm run build_tsc && npm run build_rego"
  },
  "dependencies": {
    "@minecraft/common": "^1.2.0",
    "@minecraft/math": "^2.3.1",
    "@minecraft/server": "^2.7.0",
    "@minecraft/server-ui": "2.1.0-beta.1.26.21-stable",
    "@minecraft/vanilla-data": "^1.21.131",
    "regolith": "^0.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "tsx": "^4.23.0"
  }
}

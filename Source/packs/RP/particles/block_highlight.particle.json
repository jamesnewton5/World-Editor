{
    "format_version": "1.10.0",
    "particle_effect": {
        "description": {
            "identifier": "world-editor:block_highlight",
            "basic_render_parameters": {
                "material": "particles_blend",
                "texture": "textures/world-editor/particles/pixel"
            }
        },
        "components": {
            "minecraft:emitter_rate_instant": {
                "num_particles": 1
            },
            "minecraft:emitter_lifetime_once": {
                "active_time": 1
            },
            "minecraft:particle_lifetime_expression": {
                "max_lifetime": 0.75
            },
            "minecraft:emitter_shape_point": {},
            "minecraft:particle_motion_parametric": {
                "relative_position": [
                    "variable.direction.x * 0.51",
                    "variable.direction.y * 0.51",
                    "variable.direction.z * 0.51"
                ]
            },
            "minecraft:particle_appearance_billboard": {
                "size": [
                    0.525,
                    0.525
                ],
                "facing_camera_mode": "direction_z",
                "direction": {
                    "mode": "custom",
                    "custom_direction": [
                        "variable.direction.x",
                        "variable.direction.y",
                        "variable.direction.z"
                    ]
                },
                "uv": {
                    "texture_width": 1,
                    "texture_height": 1,
                    "uv": [
                        0,
                        0
                    ],
                    "uv_size": [
                        1,
                        1
                    ]
                }
            },
            "minecraft:particle_appearance_tinting": {
                "color": {
                    "interpolant": "v.particle_age / v.particle_lifetime",
                    "gradient": {
                        "0.0": "#00FFFFFF",
                        "0.25": "#3FFFFFFF",
                        "0.75": "#3FFFFFFF",
                        "1.0": "#00FFFFFF"
                    }
                }
            }
        }
    }
}